---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Application Received | Well-Vie">
	<main>
		<section class="confirmation slide">
			<h1>Thank You for Sharing</h1>
			<p>Thank you for taking the time to complete this questionnaire.</p>
			<p>
				We intentionally keep our spaces intimate to ensure every woman feels
				supported and aligned with the experience.
			</p>
			<p>
				We'll personally review your application and follow up with next steps
				within 2-3 business days.
			</p>
			<p>
				We look forward to getting to know you and welcoming you to Well-Vie.
			</p>
			<p class="signoff">
				With love,<br />
				The Well-Vie Team
			</p>
			<a href="/reset/" class="btn">Return to The Reset</a>
		</section>
	</main>
</Layout>

<style>
	main {
		display: flex;
		justify-content: center;
		padding: var(--section-gap) 2rem;
	}

	.confirmation {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		max-width: 720px;
		text-align: center;
	}

	h1 {
		color: var(--fg-color);
	}

	p {
		line-height: 1.8;
	}

	.signoff {
		margin-top: 0.5rem;
	}

	.btn {
		margin-top: var(--small-gap);
	}
</style>
