---
import Layout from "@/layouts/Layout.astro";

const portalItems = [
	{
		label: "Community Calendar",
		iconPaths: [
			"M6 2v4M18 2v4M3 9h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z",
		],
	},
	{
		label: "Live Workshop Access",
		iconPaths: [
			"M15 10l5-3v10l-5-3M4 6h9a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z",
		],
	},
	{
		label: "Session Replays",
		iconPaths: [
			"M4.05 11a8 8 0 1 1 2.3 6.65M4 5v6h6M10 9l5 3-5 3Z",
		],
	},
	{
		label: "Guided Breathwork Library",
		iconPaths: [
			"M3 8h10a3 3 0 1 0-3-3M3 12h15a3 3 0 1 1-3 3M3 16h7a3 3 0 1 1-3 3",
		],
	},
	{
		label: "Body Scan Meditations",
		iconPaths: [
			"M12 5a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM8 22l1-7-3-3 2-4h8l2 4-3 3 1 7M9 8l3 5 3-5",
		],
	},
	{
		label: "Daily Intentions & Affirmations",
		iconPaths: [
			"M20.8 4.6a5.4 5.4 0 0 0-7.6 0L12 5.8l-1.2-1.2a5.4 5.4 0 0 0-7.6 7.6L12 21l8.8-8.8a5.4 5.4 0 0 0 0-7.6ZM18 1v4M16 3h4",
		],
	},
	{
		label: "Journal Prompts & Reflection Exercises",
		iconPaths: [
			"M5 3h12a2 2 0 0 1 2 2v16H7a2 2 0 0 1-2-2V3ZM5 7H3M5 12H3M5 17H3M9 8h6M9 12h6M9 16h4",
		],
	},
	{
		label: "Community Space",
		iconPaths: [
			"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75",
		],
	},
	{
		label: "Program Resources",
		iconPaths: [
			"M3 7h6l2 2h10v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7ZM3 7V5a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v2",
		],
	},
];
---

<Layout title="The Reset | Well-Vie">
	<main>
		<section class="hero slide">
			<span class="hero-label">Path 1</span>
			<h1>The Reset</h1>
			<p class="subtitle">
				For women seeking deeper connection, nervous system support, breathwork,
				and intentional community.
			</p>
			<p>
				A 3-week experience designed to help women slow down, reflect,
				reconnect to themselves, and experience breathwork, nervous system
				support, community, and honest conversation.
			</p>
			<p class="program-format">
				Live online &bull; Open worldwide &bull; Replays included
			</p>
			<a href="#what-to-expect" class="btn">Begin Your Journey</a>
		</section>

		<hr class="divider" />

		<section id="what-to-expect" class="expect">
			<h2 class="slide">Inside The Reset</h2>
			<div class="week-list">
				<article class="week-card slide">
					<h3>Week One</h3>
					<h4>Connect &amp; Set Intentions</h4>
					<p>
						Our first week is designed to help you slow down and reconnect.
					</p>
					<p>
						Together, we'll begin with a 90-minute LIVE community call where
						you'll meet the women inside your group, share introductions, and
						set intentions for the journey ahead. We'll move through a guided
						breathwork session and explore simple nervous system practices to
						support you throughout the week.
					</p>
					<p>
						You'll also receive journal prompts and reflection exercises to help
						you integrate the experience and reconnect with yourself in everyday
						life.
					</p>
					<p class="week-emphasis">
						<strong>
							This week is about building a foundation and creating space for
							what comes next.
						</strong>
					</p>
				</article>

				<article class="week-card slide">
					<h3>Week Two</h3>
					<h4>Deepen &amp; Receive Support</h4>
					<p>Our second week is designed to help you go deeper.</p>
					<p>
						Together, we'll gather for a 90-minute LIVE session beginning with a
						guided breathwork and nervous system reset. From there, we'll move
						into meaningful conversation centered around what you're currently
						navigating and wanting support with.
					</p>
					<p>
						You'll learn practical somatic tools to bring into everyday life,
						have space to ask questions, and connect with other women walking
						through similar seasons.
					</p>
					<p class="week-emphasis">
						<strong>
							This week is about feeling seen, supported, and remembering that
							you don't have to carry everything alone.
						</strong>
					</p>
				</article>

				<article class="week-card slide">
					<h3>Week Three</h3>
					<h4>Reconnect &amp; Reset</h4>
					<p>
						Our final week is designed to help you integrate and move forward
						with intention.
					</p>
					<p>
						We'll come together for a 90-minute LIVE closing session,
						reconnecting through guided breathwork, reflection, and integration.
						This is an opportunity to celebrate your growth, revisit the
						intentions you set at the beginning of the experience, and create
						space for what comes next.
					</p>
					<p>
						You'll leave with practices and journal prompts to continue
						supporting yourself long after the three weeks have ended.
					</p>
					<p>
						This week is about honoring how far you've come and moving forward
						with greater clarity, connection, and self-awareness.
					</p>
				</article>

				<article class="program-included portal-included slide">
					<h3>Your Well-Vie Portal</h3>
					<p>
						Throughout The Reset, you'll have access to your private Well-Vie
						member portal. A calm, organized space where everything lives in one
						place. It's designed to support you between our live sessions and give
						you a space to return to whenever you need it.
					</p>
					<ul class="portal-grid">
						{
							portalItems.map(({ label, iconPaths }) => (
								<li>
									<svg
										viewBox="0 0 24 24"
										aria-hidden="true"
										focusable="false"
									>
										{iconPaths.map((path) => <path d={path} />)}
									</svg>
									<span>{label}</span>
								</li>
							))
						}
					</ul>
				</article>

				<article class="program-included slide">
					<h3>Included Throughout</h3>
					<ul class="included-throughout-list">
						<li>Three LIVE 90-minute sessions</li>
						<li>Guided breathwork journeys</li>
						<li>Nervous system support and somatic practices</li>
						<li>Journal prompts and reflection exercises</li>
						<li>Community and connection</li>
						<li>Replay access available if life gets in the way</li>
						<li>An intimate group setting (limited to 15 women)</li>
					</ul>
				</article>

				<article class="bonus-card slide">
					<p class="section-label">Bonus Feature</p>
					<h3>Private WhatsApp Community</h3>
					<p>
						Throughout the three weeks, you'll have access to a private
						WhatsApp group with the women inside your cohort. This space is
						open for questions, reflections, celebrations, and honest
						conversations as you move through the experience together.
					</p>
					<p>
						Think of it as an extension of our calls&mdash;a place to feel
						supported, stay connected, and remember that you don't have to
						navigate this journey alone.
					</p>
					<p class="week-emphasis">
						<strong>
							Some of the most meaningful moments happen between the calls.
						</strong>
					</p>
				</article>
			</div>
		</section>

		<section class="details slide">
			<div class="details-inner">
				<h2>Details</h2>
				<div class="details-grid">
					<div class="detail-item">
						<dt>Start Date</dt>
						<dd>September 15, 2026</dd>
					</div>
					<div class="detail-item">
						<dt>Investment</dt>
						<dd>USD $333</dd>
					</div>
				</div>
				<p>Optional payment plan available.</p>
				<p class="limited">
					Spots are intentionally limited to 15 women to preserve the intimacy
					and intentionality of the experience.
				</p>
				<a href="/reset/apply/" class="btn">Apply</a>
			</div>
		</section>

		<section class="closing slide">
			<h2>What Comes After?</h2>
			<p>
				Women who complete Path I will receive priority access to Path II &
				Path III, retreats, workshops, in-person gatherings and future Well-Vie
				experiences.
			</p>
			<a href="/ecosystem/#path-ii-waitlist" class="btn">Join the Waitlist</a>
		</section>
	</main>
</Layout>

<style>
	main {
		margin: 0 auto;
		padding: 0 2rem;
		padding-top: var(--section-gap);
		padding-bottom: var(--section-gap);
		max-width: 900px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: calc(var(--section-gap) * 0.82);
	}

	/* Hero */
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: var(--small-gap);
		padding-block: var(--element-gap);
	}

	.hero-label {
		font-family: var(--gt-walsheim);
		font-size: var(--paragraph);
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--text-color);
	}

	.hero h1 {
		font-size: var(--subheading);
		color: var(--fg-color);
		margin-top: 0.25rem;
	}

	.hero .subtitle {
		font-family: var(--roslindale);
		font-size: var(--heading-paragraph);
		color: var(--fg-color);
		max-width: 600px;
		margin-top: var(--small-gap);
	}

	.hero > p:not(.subtitle) {
		max-width: 580px;
		line-height: 1.8;
	}

	.hero .program-format {
		font-weight: 500;
	}

	.hero .btn {
		margin-top: var(--element-gap);
	}

	/* Dividers */
	.divider {
		width: 60px;
		border: none;
		border-top: 1px solid var(--fg-light-color);
		margin: 0;
	}

	/* Inside The Reset */
	.expect {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: calc(var(--element-gap) * 0.9);
		width: 100%;
		scroll-margin-top: 2rem;
	}

	.week-list {
		display: flex;
		flex-direction: column;
		gap: calc(var(--element-gap) * 1.45);
		width: 100%;
		max-width: 720px;
	}

	.week-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding-bottom: calc(var(--element-gap) * 1.45);
		border-bottom: 1px solid var(--fg-light-color);
	}

	.week-card:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}

	.week-card h3 {
		color: var(--fg-color);
		font-size: clamp(2.5rem, 7vw, 4rem);
		line-height: 1;
	}

	.week-card h4 {
		font-family: var(--roslindale);
		font-size: var(--heading-paragraph);
		color: var(--fg-color);
		font-weight: normal;
	}

	.week-card p {
		max-width: 620px;
		line-height: 1.75;
	}

	.week-emphasis {
		margin-top: 0.5rem;
	}

	.program-included,
	.bonus-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding-top: calc(var(--element-gap) * 0.35);
	}

	.program-included h3,
	.bonus-card h3 {
		font-size: clamp(2.5rem, 7vw, 4rem);
		line-height: 1;
	}

	.portal-included p {
		max-width: 620px;
		line-height: 1.75;
	}

	.portal-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0;
		width: 100%;
		margin-top: 0.75rem;
		padding: 0;
		border-top: 1px solid var(--fg-color);
		border-left: 1px solid var(--fg-color);
		list-style: none;
	}

	.portal-grid li {
		display: flex;
		min-height: 125px;
		padding: 1.1rem 0.75rem;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.65rem;
		border-right: 1px solid var(--fg-color);
		border-bottom: 1px solid var(--fg-color);
		border-radius: 0;
		color: var(--text-color);
		font-size: 0.95rem;
		line-height: 1.35;
		text-align: center;
	}

	.portal-grid svg {
		width: 27px;
		height: 27px;
		color: var(--fg-color);
		fill: none;
		stroke: currentColor;
		stroke-width: 1.5;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.included-throughout-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		list-style: none;
		color: var(--text-color);
		font-size: var(--paragraph);
	}

	.included-throughout-list li {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
	}

	.included-throughout-list li::before {
		content: "";
		display: inline-block;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background-color: var(--fg-light-color);
		flex-shrink: 0;
	}

	.section-label {
		font-family: var(--gt-walsheim);
		font-size: 1rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--text-color);
	}

	.bonus-card p:not(.section-label) {
		max-width: 620px;
		line-height: 1.75;
	}

	/* Details band */
	.details {
		width: calc(100% + 4rem);
		margin-inline: -2rem;
		background-color: var(--fg-color);
		border-radius: var(--border-radius);
		padding: var(--section-gap) 2rem;
	}

	.details-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: var(--small-gap);
		max-width: 500px;
		margin: 0 auto;
	}

	.details-inner h2 {
		color: var(--bg-color);
		margin-bottom: var(--small-gap);
	}

	.details-grid {
		display: flex;
		gap: var(--horizontal-gap);
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: var(--small-gap);
	}

	.detail-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
	}

	.detail-item dt {
		font-family: var(--roslindale);
		font-size: var(--heading-paragraph);
		color: var(--bg-color);
	}

	.detail-item dd {
		font-family: var(--gt-walsheim);
		font-size: var(--paragraph);
		color: var(--bg-color);
		margin: 0;
		font-weight: 500;
	}

	.details-inner p {
		color: var(--bg-color);
		line-height: 1.7;
	}

	.details-inner .limited {
		font-style: italic;
		margin-top: var(--small-gap);
		opacity: 0.85;
	}

	/* Closing */
	.closing {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: var(--small-gap);
	}

	.closing h2 {
		margin-bottom: var(--small-gap);
	}

	.closing p {
		max-width: 580px;
		line-height: 1.8;
	}

	.closing .btn {
		margin-top: var(--element-gap);
	}

	@media (max-width: 680px) {
		.portal-grid {
			grid-template-columns: 1fr;
		}

		.portal-grid li {
			min-height: 105px;
		}
	}
</style>
