---
const formEndpoint =
	import.meta.env.PUBLIC_WELL_VIE_FORM_ENDPOINT ??
	"https://aybrcwtmggiwyzfpwfil.supabase.co/functions/v1/well-vie-forms";
const confirmationUrl =
	"https://well-vie-ecosystem-preview.surge.sh/ecosystem/waitlist-confirmation/";
---

<section id="path-ii-waitlist" class="waitlist-section slide">
	<div class="waitlist-heading">
		<p class="section-label">Opening January 2027</p>
		<h2>Join the Waitlist</h2>
		<p>
			Share a few details and you'll be the first to hear when applications
			open for Path II.
		</p>
	</div>

	<form
		class="waitlist-form"
		action={formEndpoint}
		method="POST"
		accept-charset="UTF-8"
	>
		<input type="hidden" name="form_type" value="ecosystem_waitlist" />
		<input type="hidden" name="redirect_url" value={confirmationUrl} />
		<input
			type="text"
			name="_honey"
			class="form-honey"
			tabindex="-1"
			autocomplete="off"
			aria-hidden="true"
		/>

		<div class="field-grid">
			<label class="field">
				<span>First Name</span>
				<input type="text" name="First Name" autocomplete="given-name" required />
			</label>

			<label class="field">
				<span>Last Name</span>
				<input type="text" name="Last Name" autocomplete="family-name" required />
			</label>

			<label class="field">
				<span>Email Address</span>
				<input type="email" name="email" autocomplete="email" required />
			</label>

			<label class="field">
				<span>Country</span>
				<input type="text" name="Country" autocomplete="country-name" required />
			</label>
		</div>

		<label class="field full-width">
			<span>What are you hoping to gain from The Ecosystem?</span>
			<textarea name="What are you hoping to gain from The Ecosystem?" required></textarea>
		</label>

		<button type="submit" class="btn">Join the Waitlist</button>
	</form>
</section>

<style>
	.waitlist-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: clamp(2rem, 5vw, var(--element-gap));
		width: 100%;
	}

	.waitlist-heading {
		max-width: 680px;
		text-align: center;
	}

	.section-label {
		margin-bottom: 0.5rem;
		font-family: var(--gt-walsheim);
		font-size: var(--paragraph);
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--text-color);
	}

	.waitlist-heading p:not(.section-label) {
		margin-top: 1rem;
		line-height: 1.8;
	}

	.waitlist-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		width: 100%;
		max-width: 860px;
	}

	.field-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.field {
		display: flex;
		flex-direction: column;
		box-sizing: border-box;
		gap: 0.7rem;
		padding: 0;
		border: 0;
		background-color: transparent;
		box-shadow: none;
	}

	.field:focus-within {
		background-color: transparent;
		box-shadow: none;
	}

	.field span {
		font-family: var(--roslindale);
		font-size: clamp(1.35rem, 2.1vw, 1.85rem);
		line-height: 1.05;
		color: var(--fg-color);
	}

	input,
	textarea {
		box-sizing: border-box;
		width: 100%;
		min-height: 54px;
		margin: 0;
		border: 1px solid var(--fg-light-color);
		border-radius: 8px;
		background-color: var(--bg-color);
		opacity: 1;
		color: var(--text-color);
		font-family: var(--gt-walsheim);
		font-size: 1rem;
		padding: 0.85rem 1rem;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	textarea {
		min-height: 170px;
		resize: vertical;
	}

	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--fg-color);
		background-color: #ffffff;
		box-shadow: 0 0 0 3px rgba(112, 139, 94, 0.16);
	}

	.full-width {
		width: 100%;
	}

	.form-honey {
		position: absolute;
		left: -10000px;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	button {
		align-self: center;
		margin-top: var(--small-gap);
	}

	@media (max-width: 700px) {
		.field-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
