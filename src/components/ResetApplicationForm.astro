---
const formEndpoint =
	import.meta.env.PUBLIC_WELL_VIE_FORM_ENDPOINT ??
	"https://aybrcwtmggiwyzfpwfil.supabase.co/functions/v1/well-vie-forms";
const confirmationUrl =
	"https://well-vie-ecosystem-preview.surge.sh/reset/application-confirmation/";

const healingJourneyOptions = [
	"Just beginning",
	"I've done some personal growth work",
	"I've been actively healing for several years",
	"Other",
];

const hopingToGainOptions = [
	"Nervous system support",
	"Emotional healing",
	"Community and connection",
	"Accountability",
	"Clarity and direction",
	"Confidence and self-trust",
	"Breathwork practices",
	"Personal growth",
	"Other",
];

const breathworkOptions = [
	"Yes, regularly",
	"A few times",
	"No, I'm completely new",
];

const supportAreaOptions = [
	"Stress or burnout",
	"Anxiety or depression",
	"Grief or loss",
	"Relationships and boundaries",
	"Motherhood",
	"Past experiences or inner child healing",
	"Self-worth and confidence",
	"Purpose and direction",
	"Life transitions or navigating a new home or country",
	"Navigating leadership, entrepreneurship, or career growth",
	"Community and connection",
	"Nervous system regulation",
	"Other",
];
---

<form
	class="application-form"
	action={formEndpoint}
	method="POST"
	accept-charset="UTF-8"
>
	<input type="hidden" name="form_type" value="reset_application" />
	<input type="hidden" name="redirect_url" value={confirmationUrl} />
	<input
		type="text"
		name="_honey"
		class="form-honey"
		tabindex="-1"
		autocomplete="off"
		aria-hidden="true"
	/>

	<div class="field-grid">
		<label class="field">
			<span>Full Name</span>
			<input type="text" name="Full Name" autocomplete="name" required />
		</label>

		<label class="field">
			<span>Email Address</span>
			<input type="email" name="email" autocomplete="email" required />
		</label>

		<label class="field">
			<span>Age</span>
			<input type="number" name="Age" min="18" inputmode="numeric" required />
		</label>

		<label class="field">
			<span>Location</span>
			<input
				type="text"
				name="Location"
				placeholder="City, Country"
				autocomplete="address-level2 country-name"
				required
			/>
		</label>
	</div>

	<fieldset>
		<legend>How would you describe where you are in your healing journey?</legend>
		<div class="options">
			{healingJourneyOptions.map((option, index) => (
				<label>
					<input
						type="radio"
						name="Healing journey"
						value={option}
						required={index === 0}
					/>
					<span>{option}</span>
				</label>
			))}
		</div>
		<label class="field other-field">
			<span>If other, tell us more</span>
			<input type="text" name="Healing journey other" />
		</label>
	</fieldset>

	<fieldset>
		<legend>What are you hoping to gain through this experience?</legend>
		<p class="field-note">Check all that apply.</p>
		<div class="options checkbox-grid">
			{hopingToGainOptions.map((option) => (
				<label>
					<input
						type="checkbox"
						name="What are you hoping to gain through this experience"
						value={option}
					/>
					<span>{option}</span>
				</label>
			))}
		</div>
		<label class="field other-field">
			<span>If other, tell us more</span>
			<input type="text" name="Experience goals other" />
		</label>
	</fieldset>

	<fieldset>
		<legend>Have you experienced breathwork before?</legend>
		<div class="options">
			{breathworkOptions.map((option, index) => (
				<label>
					<input
						type="radio"
						name="Breathwork experience"
						value={option}
						required={index === 0}
					/>
					<span>{option}</span>
				</label>
			))}
		</div>
	</fieldset>

	<fieldset>
		<legend>What areas of your life are you currently seeking support in?</legend>
		<p class="field-note">Check all that apply.</p>
		<div class="options checkbox-grid">
			{supportAreaOptions.map((option) => (
				<label>
					<input
						type="checkbox"
						name="Areas currently seeking support"
						value={option}
					/>
					<span>{option}</span>
				</label>
			))}
		</div>
		<label class="field other-field">
			<span>If other, tell us more</span>
			<input type="text" name="Support areas other" />
		</label>
	</fieldset>

	<label class="field full-width">
		<span>What kind of support are you looking for right now?</span>
		<textarea name="Current support needed" required></textarea>
	</label>

	<label class="field full-width">
		<span>What are you hoping life feels like on the other side of this work?</span>
		<textarea name="Life on the other side" required></textarea>
	</label>

	<label class="field full-width">
		<span>Why does now feel like the right time for you?</span>
		<textarea name="Why now" required></textarea>
	</label>

	<label class="field full-width">
		<span>Is there anything else you'd like us to know?</span>
		<textarea name="Anything else"></textarea>
	</label>

	<button type="submit" class="btn">Submit Application</button>
</form>

<style>
	.application-form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		width: 100%;
		max-width: 920px;
		margin: 0 auto;
	}

	.field-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}

	fieldset {
		box-sizing: border-box;
		border: 1px solid var(--fg-light-color);
		border-radius: 8px;
		background-color: rgba(250, 255, 255, 0.45);
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	fieldset:focus-within {
		border-color: var(--fg-color);
		background-color: rgba(250, 255, 255, 0.72);
		box-shadow: 0 12px 34px rgba(112, 139, 94, 0.1);
	}

	.field {
		display: flex;
		flex-direction: column;
		box-sizing: border-box;
		gap: 0.7rem;
		padding: 0;
		border: 0;
		background-color: transparent;
		box-shadow: none;
	}

	.field:focus-within {
		background-color: transparent;
		box-shadow: none;
	}

	.field span,
	legend {
		font-family: var(--roslindale);
		font-size: clamp(1.35rem, 2.1vw, 1.85rem);
		line-height: 1.05;
		color: var(--fg-color);
	}

	fieldset {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.15rem 1.25rem;
	}

	legend {
		padding: 0 0.5rem;
		line-height: 1.1;
	}

	.field-note {
		margin: 0;
		font-size: 1rem;
		color: var(--text-color);
	}

	input,
	textarea {
		box-sizing: border-box;
		width: 100%;
		min-height: 54px;
		margin: 0;
		border: 1px solid var(--fg-light-color);
		border-radius: 8px;
		background-color: var(--bg-color);
		opacity: 1;
		color: var(--text-color);
		font-family: var(--gt-walsheim);
		font-size: 1rem;
		padding: 0.85rem 1rem;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	textarea {
		min-height: 150px;
		resize: vertical;
	}

	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--fg-color);
		background-color: #ffffff;
		box-shadow: 0 0 0 3px rgba(112, 139, 94, 0.16);
	}

	.options {
		display: grid;
		gap: 0.75rem;
	}

	.checkbox-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		row-gap: 1rem;
	}

	.options label {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: var(--text-color);
	}

	.options label span {
		line-height: 1.12;
	}

	.checkbox-grid label {
		align-items: flex-start;
	}

	.options input {
		flex: 0 0 1.15rem;
		width: 1.15rem;
		height: 1.15rem;
		min-height: 1.15rem;
		margin: 0;
		opacity: 1;
		padding: 0;
		transform: translateY(1px);
		accent-color: var(--fg-color);
	}

	.checkbox-grid input {
		transform: translateY(0.42rem);
	}

	.other-field {
		gap: 0.45rem;
	}

	.other-field:focus-within {
		background-color: transparent;
		box-shadow: none;
	}

	.other-field span {
		font-family: var(--gt-walsheim);
		font-size: 0.95rem;
		line-height: 1.4;
		color: var(--text-color);
	}

	.full-width {
		width: 100%;
	}

	.form-honey {
		position: absolute;
		left: -10000px;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	button {
		align-self: center;
	}

	@media (max-width: 700px) {
		.field-grid,
		.checkbox-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
